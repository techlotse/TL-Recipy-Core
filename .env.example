NODE_ENV=production
PORT=8080
APP_PORT=8080
DOCKER_IMAGE=techlotse/tl-recipe-core:v0.5.1
DATABASE_URL=postgres://tl_recipe:tl_recipe@db:5432/tl_recipe_core
DATABASE_STARTUP_RETRIES=30
DATABASE_STARTUP_RETRY_MS=2000
APP_SECRET=replace-with-a-long-random-secret
SEED_SAMPLE_DATA=true

# Optional server-side fallback. Settings page values are stored encrypted in the database.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_BASE_URL=https://api.openai.com/v1
